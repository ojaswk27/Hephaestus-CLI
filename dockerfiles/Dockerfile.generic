FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    gcc-12 \
    linux-tools-common \
    linux-tools-generic \
    && rm -rf /var/lib/apt/lists/*

RUN PERF=$(ls /usr/lib/linux-tools/*/perf 2>/dev/null | head -1) && \
    ln -sf "$PERF" /usr/local/bin/perf

WORKDIR /work
CMD ["sleep", "infinity"]
