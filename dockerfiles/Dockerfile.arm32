FROM --platform=linux/arm/v7 ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc linux-tools-common linux-tools-generic \
    && rm -rf /var/lib/apt/lists/*
RUN PERF=$(ls /usr/lib/linux-tools/*/perf 2>/dev/null | head -1) && \
    [ -n "$PERF" ] && ln -sf "$PERF" /usr/local/bin/perf || true
WORKDIR /work
CMD ["sleep", "infinity"]
